NODE_ENV=development
PORT=3000
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# --- Supabase Postgres ---
# Use the "Connection string" (URI) from Supabase: Project Settings -> Database.
# Example (shared pooler IPv4):
# postgres://postgres.<project-ref>:password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgres://postgres.projectref:password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Set to "false" to disable SSL for local Postgres dev setups (Supabase requires SSL; leave unset in production).
# PGSSL=false

# Optional Postgres tuning for serverless runtimes
# PG_CONNECT_TIMEOUT_MS=5000
# PG_QUERY_TIMEOUT_MS=10000
# PG_POOL_MAX=3

# Comma-separated list of allowed browser origins.
# Example: https://invoice.hyperwrike.com,https://admin.hyperwrike.com
CORS_ORIGIN=http://localhost:3000

# Comma-separated admin email allowlist.
ADMIN_EMAILS=admin@yourcompany.com

# Public signup should remain disabled in production.
ALLOW_PUBLIC_SIGNUP=true
